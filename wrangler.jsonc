{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "gimmie-stuff",
  "main": "src/index.ts",
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2025-09-27",
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "79f7c9c2a4e94d7081f5493107ee07b9",
      "localConnectionString": "$LOCAL_CONNECTION_STRING",
    },
  ],
}
